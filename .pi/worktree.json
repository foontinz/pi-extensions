{
  "copy": [
    ".github",
    ".pi",
    ".gitignore",
    "README.md",
    "package.json",
    "package-lock.json",
    "extensions/*"
  ],
  "exclude": [
    "**/node_modules/**",
    "**/.run-*/**",
    "**/.handle-registry*.json",
    "**/.envvar-registry*.json",
    "**/.DS_Store"
  ],
  "postCopy": [
    {
      "command": "npm install --ignore-scripts --no-audit --no-fund",
      "timeoutMs": 120000,
      "optional": false
    }
  ],
  "keepWorktree": "onFailure"
}
